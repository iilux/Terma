{
  "name": "terma",
  "version": "0.3.0",
  "private": true,
  "description": "Terma — émulateur de terminal moderne (Electron + React + xterm.js)",
  "author": "",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:renderer": "vite",
    "build": "vite build",
    "rebuild": "electron-rebuild -f -w node-pty",
    "icons": "electron scripts/generate-icons.js",
    "dist": "npm run build && electron-builder",
    "postinstall": "patch-package && electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.22.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "patch-package": "^8.0.1",
    "vite": "^8.1.2",
    "wait-on": "^9.0.10"
  }
}
